# ─── FRONTEND ENVIRONMENT VARIABLES ────────────────────────────────────────────
# Copy this file to .env for local development
# For Railway: set these in the frontend service's Variables tab

# REQUIRED — URL of your Flask backend on Railway
# Example: https://inmova-backend-production.up.railway.app
# DO NOT add a trailing slash
VITE_API_URL=https://your-backend.up.railway.app

# ── Local development ────────────────────────────────────────────────────────
# For local dev, leave VITE_API_URL empty — Vite proxy handles /api automatically
# VITE_API_URL=
